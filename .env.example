# MEXC Futures API Keys
# Βρες τα στο: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_api_key_here
MEXC_SECRET_KEY=your_secret_key_here

# Mode: true = MEXC Demo (paper trading), false = Live
USE_TESTNET=true

# Risk Management
RISK_PERCENT=2

# Server port
PORT=8080

# Scan intervals (milliseconds)
SCAN_INTERVAL_MS=60000
PRICE_INTERVAL_MS=15000
